# Client (Vite) configuration
VITE_API_BASE_URL=http://localhost:5000

# Server configuration
PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/drcloud?retryWrites=true&w=majority

# CORS (for local dev)
CORS_ORIGIN=http://localhost:5173

# SMTP / email configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="DrCloud Support <no-reply@drcloud.co.in>"

# Where to send enquiry notifications (defaults to SMTP_FROM if omitted)
NOTIFY_EMAIL_TO=bhuvaneshchaudhari00@gmail.com

